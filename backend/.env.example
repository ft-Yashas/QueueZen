# PostgreSQL Database Connection
# For local development: postgresql://user:password@localhost:5432/queuezen
# For production: use your actual PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/queuezen

# JWT Secret (change this to a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=5000

# Frontend URL for CORS (change for production)
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# Anthropic API Key (required for AI wait time predictions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here